{
  "version": 1,
  "baseStyle": "bridge-cross-lamdice-casual-pixel-v2",
  "sheets": {
    "players": {
      "label": "Player Token ROYGBIV",
      "image": "players-blue.png",
      "grid": {
        "columns": 4,
        "rows": 6
      },
      "anchor": {
        "x": 0.5,
        "y": 0.88
      },
      "defaultScale": 0.62,
      "paletteOrder": ["red", "orange", "yellow", "green", "blue", "indigo", "violet"],
      "paletteImages": {
        "red": "players-red.png",
        "orange": "players-orange.png",
        "yellow": "players-yellow.png",
        "green": "players-green.png",
        "blue": "players-blue.png",
        "indigo": "players-indigo.png",
        "violet": "players-violet.png"
      },
      "animations": {
        "idle": {
          "row": 0,
          "frames": [0, 1, 2, 3],
          "fps": 5,
          "loop": true
        },
        "run": {
          "row": 1,
          "frames": [0, 1, 2, 3],
          "fps": 8,
          "loop": true
        },
        "jump": {
          "row": 2,
          "frames": [0, 1, 2, 3],
          "fps": 7,
          "loop": false
        },
        "land": {
          "row": 3,
          "frames": [0, 1, 2, 3],
          "fps": 8,
          "loop": false
        },
        "fall": {
          "row": 4,
          "frames": [0, 1, 2, 3],
          "fps": 7,
          "loop": false
        },
        "result": {
          "row": 5,
          "frames": [0, 1, 2, 3],
          "fps": 5,
          "loop": true
        }
      }
    },
    "glassFx": {
      "label": "Glass / FX",
      "image": "glass-fx-v2.png",
      "grid": {
        "columns": 4,
        "rows": 6
      },
      "anchor": {
        "x": 0.5,
        "y": 0.62
      },
      "defaultScale": 0.72,
      "animations": {
        "safe_sparkle": {
          "row": 0,
          "frames": [0, 1, 2, 3],
          "fps": 7,
          "loop": true
        },
        "warning_glow": {
          "row": 1,
          "frames": [0, 1, 2, 3],
          "fps": 7,
          "loop": true
        },
        "crack": {
          "row": 2,
          "frames": [0, 1, 2, 3],
          "fps": 8,
          "loop": false
        },
        "break_shards": {
          "row": 3,
          "frames": [0, 1, 2, 3],
          "fps": 7,
          "loop": false
        },
        "fall_trail": {
          "row": 4,
          "frames": [0, 1, 2, 3],
          "fps": 8,
          "loop": true
        },
        "landing_pulse": {
          "row": 5,
          "frames": [0, 1, 2, 3],
          "fps": 8,
          "loop": false
        }
      }
    }
  }
}
