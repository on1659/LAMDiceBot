{
  "permissions": {
    "allow": [
      "Bash(railway list:*)",
      "Bash(railway status:*)",
      "Bash(python3 -c \":*)"
    ],
    "additionalDirectories": [
      "d:\\Work\\LAMDiceBot\\.claude",
      "d:\\Work\\LAMDiceBot\\docs"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-main-branch.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/ui-check.py\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/file-type-reminder.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"이 세션에서 새로 알게 된 패턴이나 결정사항이 있다면 MEMORY.md에 기록하세요.\"}'"
          }
        ]
      }
    ]
  }
}
